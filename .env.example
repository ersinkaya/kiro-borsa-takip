# Borsa Takip - Ortam Değişkenleri
# Production'da docker-compose.yml'de tanımlanır

# Veritabanı
DB_HOST=db
DB_PORT=5432
DB_NAME=borsa_takip
DB_USER=borsa_user
DB_PASSWORD=your-secure-password

# Auth
JWT_SECRET=your-jwt-secret-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APP_URL=https://www.finanswebte.com

# AI Analiz
GROQ_API_KEY=your-groq-api-key
